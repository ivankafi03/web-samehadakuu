// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// enum Role {
//   ADMIN
//   MEMBER
// }

// enum PayoutStatus {
//   PENDING
//   APPROVED
//   REJECTED
// }

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  image         String?
  role          String    @default("MEMBER") // ADMIN, MEMBER
  balanceWatch     Float    @default(0)
  balanceReferral  Float    @default(0)
  balanceBonus     Float    @default(0)

  // Anti-bot & Security
  registrationIp   String?  // IP used during registration (for account limit per IP)
  deviceFingerprint String? // Browser fingerprint for multi-account detection
  isFlagged        Boolean  @default(false) // Anomaly detected — silent flag for admin review
  flagReason       String?  // Reason for flagging (e.g. "Earning anomaly")
  isSuspended      Boolean  @default(false) // Account suspended by admin — blocks login
  isBot            Boolean  @default(false) // Fake/seeded member for leaderboard display only
  
  registrationBonusClaimed Boolean @default(false)

  // Relations
  referralViews ReferralView[]
  selfViews     SelfView[]
  payouts       PayoutRequest[]
  collectedLinks CollectedLink[]
  watchHistory  WatchHistory[]
  claims        UserClaim[]
  
  // Registration Referral Tracking
  referredById  String?
  referredBy    User?      @relation("UserReferrals", fields: [referredById], references: [id])
  referrals     User[]     @relation("UserReferrals")
  withdrawals   WithdrawRequest[]
  earningLogs   EarningLog[]
  chatMessages  ChatMessage[]
  comments      Comment[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model CollectedLink {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  videoId     String
  videoTitle  String
  videoUrl    String
  
  createdAt   DateTime @default(now())
}

model ReferralView {
  id          String   @id @default(cuid())
  referrerId  String
  referrer    User     @relation(fields: [referrerId], references: [id])
  
  videoId     String   // The slug or ID of the video
  ipAddress   String   // Anti-fraud: prevent same IP abuse
  userAgent   String?
  duration    Int      @default(0) // Dwell time in seconds
  
  isValid     Boolean  @default(false) // Whether it met the 60s criteria
  isSkimmed   Boolean  @default(false) // Whether this view was "swallowed" by admin
  
  createdAt   DateTime @default(now())
}

model PayoutRequest {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  
  amount         Float
  status         String       @default("PENDING") // PENDING, APPROVED, REJECTED
  paymentMethod  String?      // e.g., "DANA", "OVO", "Bank"
  paymentDetails String?      // Nomor HP atau Rekening
  
  processedAt    DateTime?
  createdAt      DateTime     @default(now())
}

model SystemSettings {
  id             String   @id @default("global")
  cpmRate        Float    @default(1.50) // in USD
  watchRate      Float    @default(0.005) // Price per watch-self
  referralRate   Float    @default(0.01)  // Price per referral view
  skimRate       Float    @default(0.20)
  minWithdrawal  Float    @default(50.00)
  maintenanceMode Boolean @default(false)
  maintenanceMessage String @default("Situs sedang dalam pemeliharaan rutin untuk meningkatkan performa.")
  registrationBonus Float @default(1.00) // Reward for joining (can be claimed)
  telegramLink   String @default("https://t.me/samehadakuu_official")
  xLink          String @default("https://x.com/samehadakuu")
  instagramLink  String @default("https://instagram.com/samehadakuu")
  tiktokLink     String @default("https://tiktok.com/@samehadakuu")
  supportEmail   String @default("support@samehadakuu.com")
  
  updatedAt      DateTime @updatedAt
}

model WithdrawRequest {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  amount        Float
  method        String   // DANA, OVO, GOPAY, BANK
  accountNumber String
  accountName   String
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SelfView {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  videoId   String
  duration  Int
  rewarded  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model WatchToken {
  id        String    @id @default(cuid())
  userId    String
  videoId   String
  token     String    @unique
  issuedAt  DateTime  @default(now())
  usedAt    DateTime?

  @@index([userId, videoId])
}

model WatchHistory {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  videoId     String
  videoTitle  String
  videoImage  String
  videoUrl    String
  
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@unique([userId, videoId])
}

model EarningLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Float
  type      String   // WATCH, REFERRAL, BONUS
  createdAt DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  videoId   String   // video slug
  content   String
  createdAt DateTime @default(now())

  @@index([videoId])
}

model AdminRotation {
  id           String   @id @default("global")
  lastRotation DateTime @default(now())
  nextRotation DateTime
}

model BlockedIp {
  id        String   @id @default(cuid())
  ip        String   @unique
  reason    String?
  blockedBy String?  // admin userId who blocked it
  createdAt DateTime @default(now())
}

model BroadcastReward {
  id        String   @id @default(cuid())
  title     String
  message   String
  amount    Float
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  claims    UserClaim[]
}

model UserClaim {
  id                String   @id @default(cuid())
  userId            String
  broadcastRewardId String
  claimedAt         DateTime @default(now())
  user              User            @relation(fields: [userId], references: [id])
  broadcastReward   BroadcastReward @relation(fields: [broadcastRewardId], references: [id])
  @@unique([userId, broadcastRewardId])
}
